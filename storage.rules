rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /medical_records/{userEmail}/{fileName} {
      // Allow authenticated clinical providers and patients to read/write medical files
      allow read, write: if request.auth != null;
    }
    match /medical_docs/{userEmail}/{fileName} {
      // Allow authenticated clinical providers and patients to read/write medical files
      allow read, write: if request.auth != null;
    }
  }
}
